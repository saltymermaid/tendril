# Database
DATABASE_URL=postgresql+asyncpg://tendril:tendril@db:5432/tendril
POSTGRES_USER=tendril
POSTGRES_PASSWORD=tendril
POSTGRES_DB=tendril

# Auth
SECRET_KEY=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=user@example.com
ENABLE_DEV_LOGIN=true

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tendril

# Push Notifications (VAPID)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# App
APP_NAME=Tendril
DEBUG=true
CORS_ORIGINS=http://localhost:5173
